{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["ultracite/core"],
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**/*.ts",
      "**/*.tsx",
      "**/*.js",
      "**/*.jsx",
      "**/*.json",
      "**/*.jsonc",
      "**/*.css",
      "!**/_generated"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false,
      "performance": {
        // Convex and other libs use namespace imports extensively
        "noNamespaceImport": "off",
        // Barrel files are standard pattern for packages/ui and backend exports
        "noBarrelFile": "off"
      },
      "style": {
        // Too noisy for UI code with prices, indices, dimensions, etc.
        "noMagicNumbers": "off",
        // Single-line if/return/arrow is acceptable and often cleaner
        "useBlockStatements": "off",
        // Convex values are often known to exist after query checks
        "noNonNullAssertion": "warn",
        // Project uses both interface and type per CLAUDE.md convention
        "useConsistentTypeDefinitions": "off",
        // Allow camelCase for hooks (useDebounce.ts) and Convex files (driverProfiles.ts)
        "useFilenamingConvention": {
          "level": "error",
          "options": {
            "requireAscii": true,
            "filenameCases": ["kebab-case", "camelCase"]
          }
        },
        // Enums are sometimes appropriate for domain models
        "noEnum": "off",
        // Nested ternaries are common in JSX conditional rendering
        "noNestedTernary": "warn",
        // Prices in cents (10000 = $100) are clearer without separators
        "useNumericSeparators": "off",
        // TypeScript exhaustiveness checks handle this better
        "useDefaultSwitchClause": "off"
      },
      "complexity": {
        // Complex UI components and backend handlers naturally exceed 15
        "noExcessiveCognitiveComplexity": {
          "level": "warn",
          "options": { "maxAllowedComplexity": 25 }
        },
        // forEach is acceptable - not always worth converting to for...of
        "noForEach": "warn",
        // Idiomatic for fire-and-forget promises
        "noVoid": "off"
      },
      "suspicious": {
        // Warn rather than error - some contexts (Convex, third-party) legitimately need any
        "noExplicitAny": "warn",
        // Console is useful in development and error boundaries
        "noConsole": "warn",
        // Rarely relevant in a web app
        "noBitwiseOperators": "off",
        // Warn during development, alerts may be intentional in some UI flows
        "noAlert": "warn",
        // Catches real issues but too noisy in Convex handlers
        "noEvolvingTypes": "warn",
        // Fix gradually, don't block CI
        "noImplicitAnyLet": "warn"
      },
      "correctness": {
        // Next.js <Image> handles sizing; native <img> used for CDN images
        "useImageSize": "off"
      },
      "a11y": {
        // Img alt text containing "image"/"photo" is acceptable for photo galleries
        "noRedundantAlt": "warn",
        // Interactive divs with onClick are common in custom UI components
        "noStaticElementInteractions": "warn",
        "noNoninteractiveElementInteractions": "warn",
        // Click handlers on divs with keyboard alternatives handled by parent
        "useKeyWithClickEvents": "warn",
        // Decorative SVGs in UI components don't always need titles
        "noSvgWithoutTitle": "warn",
        // Semantic elements not always applicable for custom component wrappers
        "useSemanticElements": "warn",
        // Labels associated via context/composition in shadcn components
        "noLabelWithoutControl": "warn",
        // Video/audio captions - warn to address progressively
        "useMediaCaption": "warn"
      },
      "nursery": {
        // Nursery rule, still unstable - warn rather than error
        "noShadow": "warn"
      }
    },
    "includes": ["**", "apps/**", "packages/**"]
  },
  "javascript": {
    "formatter": {
      "trailingCommas": "es5",
      "semicolons": "asNeeded",
      "quoteStyle": "double"
    }
  },
  "json": { "formatter": { "enabled": true } },
  "overrides": [
    {
      // Tailwind v4 globals - Biome CSS parser doesn't support @custom-variant media syntax
      "includes": ["packages/ui/src/styles/globals.css"],
      "linter": { "enabled": false },
      "formatter": { "enabled": false }
    },
    {
      // Convex backend - relax rules for serverless function contexts
      "includes": ["packages/backend/convex/**/*"],
      "linter": {
        "rules": {
          "suspicious": {
            // Convex context types are complex and sometimes need any
            "noExplicitAny": "off",
            // Backend logging is expected
            "noConsole": "off"
          },
          "style": {
            // Convex generated files use camelCase
            "useFilenamingConvention": "off"
          }
        }
      }
    },
    {
      // Test files - vitest globals (describe, it, expect) trigger noUndeclaredVariables
      "includes": ["**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts"],
      "linter": {
        "rules": {
          "correctness": {
            "noUndeclaredVariables": "off"
          }
        }
      }
    }
  ]
}
